# ── General ────────────────────────────────────────────────────────────────────
aws_region  = "ap-south-1"       # Mumbai — cheapest Graviton region
app_name    = "salon-booking"

# ── EC2 Instance ───────────────────────────────────────────────────────────────
instance_type = "t4g.micro"      # ARM64 Graviton2 — required for PostgreSQL RAM

# ── Docker ─────────────────────────────────────────────────────────────────────
docker_image = "yourdockerhubusername/flask-crud:latest"

# ── Flask ──────────────────────────────────────────────────────────────────────
flask_env        = "production"
flask_secret_key = ""            # generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── SSH Access ─────────────────────────────────────────────────────────────────
ssh_public_key_path = "~/.ssh/id_rsa.pub"   # path to your public key
ssh_allowed_cidr    = "0.0.0.0/0"           # restrict to your IP for better security e.g. "1.2.3.4/32"

# ── EBS Volume (PostgreSQL data) ───────────────────────────────────────────────
db_volume_size_gb = 10           # GB — has prevent_destroy = true, survives terraform destroy

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
postgres_db       = "flask_crud"
postgres_user     = "your_db_user"
postgres_password = "your_db_password"      # use a strong password

# ── pgAdmin ────────────────────────────────────────────────────────────────────
pgadmin_email    = "your@email.com"
pgadmin_password = "your_pgadmin_password"
pgadmin_port     = 5050
