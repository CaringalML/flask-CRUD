# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is in .gitignore — never commit it.

aws_region          = "ap-south-1"
app_name            = "salon-booking"
instance_type       = "t4g.micro"
docker_image        = "rencecaringal000/flask-crud:latest"
flask_env           = "production"
ssh_public_key_path = "~/.ssh/id_rsa.pub"
ssh_allowed_cidr    = "0.0.0.0/0"   # Restrict to your IP: "1.2.3.4/32"
db_volume_size_gb   = 10

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
flask_secret_key    = "replace-with-a-long-random-string"

# PostgreSQL credentials
postgres_db         = "flask_crud"
postgres_user       = "flask_user"
postgres_password   = "replace-with-strong-password"

# pgAdmin credentials
pgadmin_email       = "admin@salon.com"
pgadmin_password    = "replace-with-strong-password"
pgadmin_port        = 5050
