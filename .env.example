# ─── Supabase ───────────────────────────────────────────────────────────────

# Your Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Service role secret key — server-side only, NEVER expose to the browser
# (Settings → API → service_role)
SUPABASE_KEY=your-service-role-secret-key

# Anon public key — safe to expose to the browser, used for Realtime
# (Settings → API → anon public)
SUPABASE_ANON_KEY=your-anon-public-key

# ─── Database ────────────────────────────────────────────────────────────────

# Used by Flask-Migrate for schema migrations (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# Local development alternative (uncomment to use)
# DATABASE_URL=postgresql://postgres:your-db-password@localhost:5432/postgres

# ─── Flask ───────────────────────────────────────────────────────────────────

# Any long random string — used to sign session cookies
SECRET_KEY=your-flask-secret-key
